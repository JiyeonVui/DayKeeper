<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Báo thức chính xác: SCHEDULE_EXACT_ALARM cho API 31-32 (người dùng cấp),
         USE_EXACT_ALARM cho API 33+ (tự cấp, app nhắc nhở đủ điều kiện dùng). -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Báo thức toàn màn hình (đè màn khoá) + rung liên tục. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Foreground Service giữ chuông báo kêu liên tục, kể cả khi màn hình đang mở. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DayKeeper">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.DayKeeper">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Màn báo thức toàn màn hình: mở qua fullScreenIntent, hiện đè màn khoá.
             Task riêng (taskAffinity rỗng) + không vào Recents để tách khỏi app. -->
        <activity
            android:name=".reminder.AlarmActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity=""
            android:theme="@style/Theme.DayKeeper" />

        <!-- Foreground Service phát chuông + rung và giữ thông báo báo thức. -->
        <service
            android:name=".reminder.AlarmSoundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Nhận báo thức nhắc nhở (nội bộ app). -->
        <receiver
            android:name=".reminder.AlarmReceiver"
            android:exported="false" />

        <!-- Lập lại lịch nhắc sau khi khởi động lại máy. -->
        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>